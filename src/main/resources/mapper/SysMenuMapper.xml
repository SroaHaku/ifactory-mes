<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mes.mapper.SysMenuMapper">

    <select id="selectMenuListByUserId">
        SELECT m.*
        FROM sys_menu m
        WHERE m.type IN (1,2)
          AND m.visible = 1
        ORDER BY m.sort ASC
    </select>

</mapper>